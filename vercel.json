{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/**/*",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/admin",
            "destination": "/frontend/admin/index.html"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/frontend/admin/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/public/$1"
        }
    ]
}